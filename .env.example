# OSFNA 2026 — Environment Variables
# Copy this to .env.local and fill in your credentials

# =============================================
# STRIPE — Payment Processing
# =============================================
STRIPE_SECRET_KEY=sk_live_YOUR_STRIPE_SECRET_KEY_HERE
STRIPE_WEBHOOK_SECRET=whsec_YOUR_WEBHOOK_SECRET_HERE

# Team Registration Prices (in USD cents)
# Get these from Stripe Dashboard → Products → Price IDs
STRIPE_TEAM_PRICE_DIV_A=price_xxxxx  # Division A Soccer ($400)
STRIPE_TEAM_PRICE_DIV_B=price_xxxxx  # Division B Soccer ($400)
STRIPE_TEAM_PRICE_DIV_C=price_xxxxx  # Division C Soccer ($300)
STRIPE_TEAM_PRICE_BASKETBALL=price_xxxxx  # Basketball ($300)
STRIPE_TEAM_PRICE_GOLF=price_xxxxx  # Golf ($250)

# Vendor Booth Prices (in USD cents)
STRIPE_VENDOR_BOOTH_10X10=price_xxxxx  # 10×10 Booth ($400)
STRIPE_VENDOR_BOOTH_10X20=price_xxxxx  # 10×20 Booth ($700)
STRIPE_VENDOR_BOOTH_CUSTOM=price_xxxxx  # Custom Booth (negotiable)

# =============================================
# SUPABASE — Database
# =============================================
SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Tables needed in Supabase:
# - teams (id, name, city, state, sport, division, coach_name, coach_email, coach_phone, roster_count, shirt_color, created_at)
# - vendors (id, business_name, owner_name, email, phone, category, booth_size, products_desc, power_needs, setup_pref, parking_passes, created_at)
# - matches (id, sport, division, round, team_a_id, team_b_id, team_a_score, team_b_score, winner_id, scheduled_at, completed_at)
# - brackets (id, sport, division, match_ids_by_round, current_round)

# =============================================
# EMAIL — Notifications (Optional)
# =============================================
SENDGRID_API_KEY=SG.xxxxx...  # SendGrid for transactional emails
SENDGRID_FROM_EMAIL=noreply@osfna.org

# =============================================
# ADMIN AUTH
# =============================================
ADMIN_API_KEY=your_secret_admin_key_here  # For /api/update-score.js access

# =============================================
# APP CONFIG
# =============================================
NEXT_PUBLIC_APP_URL=https://osfna-2026.vercel.app
NEXT_PUBLIC_STRIPE_PUBLIC_KEY=pk_live_YOUR_PUBLIC_KEY_HERE  # Required for frontend checkout
VAPID_PUBLIC_KEY=BNXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
VAPID_PRIVATE_KEY=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
VAPID_SUBJECT=mailto:alerts@osfna.org
PUSH_ADMIN_KEY=your_push_dispatch_secret_here

# =============================================
# Notes:
# 1. Get Stripe keys from: https://dashboard.stripe.com/account/apikeys
# 2. Get Supabase keys from: https://app.supabase.com → Project Settings → API
# 3. Make sure NEXT_PUBLIC_* variables are only for public use (no secrets)
# 4. Never commit this file! Add to .gitignore
#
